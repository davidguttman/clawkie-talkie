{
  "name": "clawkie-talkie",
  "version": "0.0.0",
  "private": true,
  "description": "Walkie-talkie voice surface for an OpenClaw session",
  "workspaces": [
    "client",
    "rendezvous",
    "daemon"
  ],
  "scripts": {
    "dev": "npm run dev --workspace client",
    "build": "npm run build --workspace client",
    "typecheck": "npm run typecheck --workspace client",
    "rendezvous": "npm run start --workspace=rendezvous --",
    "daemon": "npm run start --workspace=daemon --"
  }
}
