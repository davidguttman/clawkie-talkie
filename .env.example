# Repo-root env for Clawkie-Talkie local dev.
#
# Copy to `.env` and fill in values. The root daemon scripts load this file
# with `tsx --env-file=.env`, so `npm run dev` and `npm run daemon` pick up
# values automatically.
#
# `.env` is gitignored — never commit your real key.

XAI_API_KEY=

# Optional hosted signaling broker override. Leave blank to use
# https://api.rambly.app. The daemon and browser must agree on this.
# (VITE_-prefixed vars are inlined into the client bundle by Vite.)
SIGNAL_SERVER=
VITE_SIGNAL_SERVER=
